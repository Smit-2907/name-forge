# NameForge Configuration Template

# Server Port
PORT=8080

# Logging Level (debug, info, warn, error)
LOG_LEVEL=debug

# Database Settings (PostgreSQL)
# Use "postgres://postgres:postgres@localhost:5432/nameforge?sslmode=disable" for local testing
DATABASE_URL=postgres://postgres:postgres@localhost:5432/nameforge?sslmode=disable

# Cache Settings (Redis)
# Use "redis://localhost:6379/0" for local testing
REDIS_URL=redis://localhost:6379/0

# Use Mock/Sandbox Provider (true for offline mock queries, false for real API queries)
USE_MOCK_PROVIDERS=true

# Worker pool configuration
WORKER_COUNT=30
CACHE_TTL_HOURS=24

# API Rate Limits (Max requests per window in milliseconds)
RATE_LIMIT_MAX=60
RATE_LIMIT_WINDOW_MS=60000

# Google AI Studio Gemini API Key (leave empty to use local fallback name generator)
GEMINI_API_KEY=

# Porkbun API Keys
PORKBUN_API_KEY=
PORKBUN_SECRET_KEY=

# Namecheap API Credentials
NAMECHEAP_USERNAME=
NAMECHEAP_API_KEY=
NAMECHEAP_CLIENT_IP=127.0.0.1

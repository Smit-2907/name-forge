# ==========================================
# NameForge Production Environment Templates
# ==========================================
# Copy this file to .env.prod in production and populate the values.
# NEVER commit the actual .env.prod file to your repository.

APP_ENV=production
PORT=8080
LOG_LEVEL=warn

# Postgres Database
# Replace with your actual production postgres URL and password
POSTGRES_PASSWORD=your-secure-postgres-password
DATABASE_URL=postgres://postgres:your-secure-postgres-password@postgres:5432/nameforge?sslmode=disable

# Redis Cache
# Replace with your actual secure redis password
REDIS_PASSWORD=your-secure-redis-password
REDIS_URL=redis://:your-secure-redis-password@redis:6379/0

# Application Performance & Rate Limiting
WORKER_COUNT=30
CACHE_TTL_HOURS=24
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# Security (CRITICAL)
# Set these to long, cryptographically secure random values.
# The app will FATAL exit on startup if defaults are used in production!
JWT_SECRET=your-production-jwt-signing-secret-key-must-be-long-and-random
ADMIN_API_KEY=your-production-admin-dashboard-access-api-key-string

# CORS Hardening (CRITICAL)
# Specify your real front-end application domain (e.g. https://nameforge.app)
# Wildcard '*' or empty values will be rejected on startup in production.
ALLOWED_ORIGINS=https://your-frontend-domain.com

# Core AI Provider Credentials
GEMINI_API_KEY=your-gemini-cloud-developer-api-key
USE_MOCK_PROVIDERS=false

# Optional Provider Credentials
# (Optional) Add Porkbun or Namecheap keys if you wish to query them.
PORKBUN_API_KEY=
PORKBUN_SECRET_KEY=
NAMECHEAP_USERNAME=
NAMECHEAP_API_KEY=
NAMECHEAP_CLIENT_IP=
